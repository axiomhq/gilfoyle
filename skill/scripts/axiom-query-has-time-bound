#!/usr/bin/env node

const fs = require('node:fs');
const path = require('node:path');
const { pathToFileURL } = require('node:url');

function resolveGilfoyleRoot() {
  if (process.env.GILFOYLE_ROOT) return process.env.GILFOYLE_ROOT;
  return path.resolve(__dirname, '..', '..');
}

async function loadAnalyzer(rootDir) {
  const wasmDir = path.join(rootDir, '.meta', 'toolbox', 'wasm');
  const wasmPath = path.join(wasmDir, 'apl-parser.wasm');
  const shimPath = path.join(wasmDir, 'wasm_exec.js');

  if (!fs.existsSync(wasmPath)) {
    throw new Error(`missing ${wasmPath} (run git lfs pull)`);
  }

  await import(pathToFileURL(shimPath).href);
  const go = new globalThis.Go();
  const wasmBuf = fs.readFileSync(wasmPath);
  const instance = await WebAssembly.instantiate(wasmBuf, go.importObject);
  go.run(instance.instance);

  if (typeof globalThis.AnalyzeAPL !== 'function') {
    throw new Error('AnalyzeAPL export not found');
  }

  return globalThis.AnalyzeAPL;
}

async function main() {
  const query = fs.readFileSync(0, 'utf8');
  const analyze = await loadAnalyzer(resolveGilfoyleRoot());
  const result = analyze(query);

  if (!result?.valid) {
    process.exit(0);
  }

  process.exit(result.requiresTimeBound && !result.hasExplicitTimeBound ? 1 : 0);
}

main().catch((error) => {
  console.error(`error: ${error.message}`);
  process.exit(2);
});
